          "default": null,
          "title": "Input Tokens"
        },
        "latency_ms": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Latency Ms"
        },
        "output_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Output Tokens"
        },
        "total_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Tokens"
        }
      },
      "title": "ProviderUsage",
      "type": "object"
    },
    "ReliabilityBin": {
      "additionalProperties": false,
      "properties": {
        "accuracy": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Accuracy"
        },
        "count": {
          "minimum": 0,
          "title": "Count",
          "type": "integer"
        },
        "lower_bound": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Lower Bound",
          "type": "number"
        },
        "mean_confidence": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mean Confidence"
        },
        "upper_bound": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Upper Bound",
