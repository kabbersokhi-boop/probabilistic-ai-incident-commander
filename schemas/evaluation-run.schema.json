    "aggregate": {
      "$ref": "#/$defs/AggregateMetrics"
    },
    "answer_key_manifest_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Answer Key Manifest Sha256",
      "type": "string"
    },
    "answer_keys": {
      "items": {
        "$ref": "#/$defs/HiddenAnswerKey"
      },
      "minItems": 1,
      "title": "Answer Keys",
      "type": "array"
    },
    "benchmark_manifest_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Benchmark Manifest Sha256",
      "type": "string"
    },
    "config": {
      "$ref": "#/$defs/EvaluationConfig"
