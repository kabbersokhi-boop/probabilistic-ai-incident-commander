    "VisibleCase": {
      "additionalProperties": false,
      "properties": {
        "allowed_tools": {
          "items": {
            "type": "string"
          },
          "maxItems": 100,
          "title": "Allowed Tools",
          "type": "array"
        },
        "case_id": {
          "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$",
          "title": "Case Id",
          "type": "string"
