        "family": {
          "maxLength": 100,
          "minLength": 1,
          "title": "Family",
          "type": "string"
        },
        "incident_input": {
          "maxLength": 20000,
          "minLength": 1,
          "title": "Incident Input",
          "type": "string"
        }
      },
      "required": [
        "case_id",
        "family",
        "incident_input"
      ],
      "title": "VisibleCase",
      "type": "object"
    }
  },
  "additionalProperties": false,
