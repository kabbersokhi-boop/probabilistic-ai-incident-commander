{
  "$defs": {
    "AblationConfig": {
      "additionalProperties": false,
      "properties": {
        "abstention_enabled": {
          "default": true,
          "title": "Abstention Enabled",
          "type": "boolean"
        },
        "max_hypotheses": {
          "default": 30,
          "maximum": 30,
          "minimum": 1,
          "title": "Max Hypotheses",
          "type": "integer"
        },
        "max_tool_calls": {
          "default": 24,
          "maximum": 100,
          "minimum": 1,
          "title": "Max Tool Calls",
          "type": "integer"
        },
        "name": {
          "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$",
          "title": "Name",
          "type": "string"
        },
        "remove_contradictions": {
          "default": false,
          "title": "Remove Contradictions",
          "type": "boolean"
        },
        "remove_history": {
          "default": false,
          "title": "Remove History",
          "type": "boolean"
        },
        "remove_lineage": {
          "default": false,
          "title": "Remove Lineage",
          "type": "boolean"
        }
      },
      "required": [
        "name"
      ],
      "title": "AblationConfig",
      "type": "object"
    },
    "AggregateMetrics": {
      "additionalProperties": false,
      "properties": {
        "abstention_accuracy": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Abstention Accuracy",
          "type": "number"
