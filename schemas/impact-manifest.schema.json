{
  "$defs": {
    "ImpactColumnManifest": {
      "additionalProperties": false,
      "properties": {
        "dtype": {
          "minLength": 1,
          "title": "Dtype",
          "type": "string"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "nullable": {
          "title": "Nullable",
          "type": "boolean"
        }
      },
      "required": [
        "name",
        "dtype",
        "nullable"
      ],
      "title": "ImpactColumnManifest",
      "type": "object"
    },
    "ImpactRuntimeManifest": {
      "additionalProperties": false,
      "properties": {
        "packages": {
          "additionalProperties": {
            "minLength": 1,
            "type": "string"
          },
          "propertyNames": {
            "minLength": 1
          },
          "title": "Packages",
          "type": "object"
        },
        "platform": {
          "minLength": 1,
          "title": "Platform",
          "type": "string"
        },
        "python_implementation": {
          "minLength": 1,
          "title": "Python Implementation",
          "type": "string"
        },
        "python_version": {
          "minLength": 1,
          "title": "Python Version",
          "type": "string"
        }
      },
      "required": [
        "python_version",
        "python_implementation",
        "platform",
        "packages"
      ],
      "title": "ImpactRuntimeManifest",
      "type": "object"
    },
    "ImpactTableManifest": {
      "additionalProperties": false,
      "properties": {
        "byte_size": {
          "minimum": 0,
          "title": "Byte Size",
          "type": "integer"
        },
        "columns": {
          "items": {
            "$ref": "#/$defs/ImpactColumnManifest"
          },
          "title": "Columns",
          "type": "array"
        },
        "maximum_timestamp": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Timestamp"
        },
        "minimum_timestamp": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Minimum Timestamp"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "primary_key": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Primary Key",
          "type": "array"
        },
        "relative_path": {
          "minLength": 1,
          "title": "Relative Path",
          "type": "string"
        },
        "row_count": {
          "minimum": 0,
          "title": "Row Count",
          "type": "integer"
        },
        "sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "name",
        "relative_path",
        "row_count",
        "byte_size",
        "sha256",
        "primary_key",
        "columns"
      ],
      "title": "ImpactTableManifest",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "customer_count": {
      "minimum": 1,
      "title": "Customer Count",
      "type": "integer"
    },
    "exposed_customer_count": {
      "minimum": 1,
      "title": "Exposed Customer Count",
      "type": "integer"
    },
    "generator_version": {
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "title": "Generator Version",
      "type": "string"
    },
    "impact_config_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Impact Config Sha256",
      "type": "string"
    },
    "impact_id": {
      "minLength": 1,
      "title": "Impact Id",
      "type": "string"
    },
    "incident_id": {
      "minLength": 1,
      "title": "Incident Id",
      "type": "string"
    },
    "logical_end_at": {
      "format": "date-time",
      "title": "Logical End At",
      "type": "string"
    },
    "logical_start_at": {
      "format": "date-time",
      "title": "Logical Start At",
      "type": "string"
    },
    "quality_error_count": {
      "minimum": 0,
      "title": "Quality Error Count",
      "type": "integer"
    },
    "runtime": {
      "$ref": "#/$defs/ImpactRuntimeManifest"
    },
    "schema_version": {
      "pattern": "^\\d+\\.\\d+$",
      "title": "Schema Version",
      "type": "string"
    },
    "source_config_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Source Config Sha256",
      "type": "string"
    },
    "source_manifest_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Source Manifest Sha256",
      "type": "string"
    },
    "source_simulation_id": {
      "minLength": 1,
      "title": "Source Simulation Id",
      "type": "string"
    },
    "tables": {
      "items": {
        "$ref": "#/$defs/ImpactTableManifest"
      },
      "title": "Tables",
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "impact_id",
    "incident_id",
    "generator_version",
    "runtime",
    "source_simulation_id",
    "source_manifest_sha256",
    "source_config_sha256",
    "impact_config_sha256",
    "logical_start_at",
    "logical_end_at",
    "customer_count",
    "exposed_customer_count",
    "quality_error_count",
    "tables"
  ],
  "title": "ImpactManifest",
  "type": "object"
}
