{
  "$defs": {
    "DecisionPolicy": {
      "additionalProperties": false,
      "properties": {
        "likelihood_ratio_max": {
          "default": 20.0,
          "exclusiveMinimum": 1.0,
          "maximum": 100.0,
          "title": "Likelihood Ratio Max",
          "type": "number"
        },
        "likelihood_ratio_min": {
          "default": 0.05,
          "exclusiveMaximum": 1.0,
          "exclusiveMinimum": 0.0,
          "title": "Likelihood Ratio Min",
          "type": "number"
        },
        "maximum_normalized_entropy": {
          "default": 0.85,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Maximum Normalized Entropy",
          "type": "number"
        },
        "minimum_distinct_evidence": {
          "default": 2,
          "maximum": 50,
          "minimum": 1,
          "title": "Minimum Distinct Evidence",
          "type": "integer"
        },
        "minimum_margin": {
          "default": 0.15,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Minimum Margin",
          "type": "number"
        },
        "minimum_top_posterior": {
          "default": 0.55,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Minimum Top Posterior",
          "type": "number"
        }
      },
      "title": "DecisionPolicy",
      "type": "object"
    },
    "InvestigationBudget": {
      "additionalProperties": false,
      "properties": {
        "max_provider_failures": {
          "default": 6,
          "maximum": 20,
          "minimum": 0,
          "title": "Max Provider Failures",
          "type": "integer"
        },
        "max_rounds": {
          "default": 10,
          "maximum": 30,
          "minimum": 1,
          "title": "Max Rounds",
          "type": "integer"
        },
        "max_tool_calls": {
          "default": 24,
          "maximum": 100,
          "minimum": 1,
          "title": "Max Tool Calls",
          "type": "integer"
        },
        "max_tool_result_bytes": {
          "default": 100000,
          "maximum": 1000000,
          "minimum": 1000,
          "title": "Max Tool Result Bytes",
          "type": "integer"
        },
        "max_total_tokens": {
          "default": 40000,
          "maximum": 500000,
          "minimum": 512,
          "title": "Max Total Tokens",
          "type": "integer"
        }
      },
      "title": "InvestigationBudget",
      "type": "object"
    },
    "ModelRoute": {
      "additionalProperties": false,
      "properties": {
        "enable_thinking": {
          "default": false,
          "title": "Enable Thinking",
          "type": "boolean"
        },
        "max_tokens": {
          "default": 4096,
          "maximum": 32768,
          "minimum": 128,
          "title": "Max Tokens",
          "type": "integer"
        },
        "model": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Model",
          "type": "string"
        },
        "reasoning_budget": {
          "default": 0,
          "maximum": 32768,
          "minimum": 0,
          "title": "Reasoning Budget",
          "type": "integer"
        },
        "temperature": {
          "default": 0.2,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Temperature",
          "type": "number"
        },
        "top_p": {
          "default": 0.95,
          "exclusiveMinimum": 0.0,
          "maximum": 1.0,
          "title": "Top P",
          "type": "number"
        }
      },
      "required": [
        "model"
      ],
      "title": "ModelRoute",
      "type": "object"
    },
    "ProviderConfig": {
      "additionalProperties": false,
      "properties": {
        "api_key_env": {
          "default": "NVIDIA_API_KEY",
          "pattern": "^[A-Z][A-Z0-9_]*$",
          "title": "Api Key Env",
          "type": "string"
        },
        "base_url": {
          "default": "https://integrate.api.nvidia.com/v1",
          "title": "Base Url",
          "type": "string"
        },
        "kind": {
          "const": "nvidia_nim",
          "default": "nvidia_nim",
          "title": "Kind",
          "type": "string"
        },
        "max_response_bytes": {
          "default": 2000000,
          "maximum": 10000000,
          "minimum": 1024,
          "title": "Max Response Bytes",
          "type": "integer"
        },
        "models": {
          "items": {
            "$ref": "#/$defs/ModelRoute"
          },
          "title": "Models",
          "type": "array"
        },
        "timeout_seconds": {
          "default": 45.0,
          "exclusiveMinimum": 0.0,
          "maximum": 120.0,
          "title": "Timeout Seconds",
          "type": "number"
        }
      },
      "required": [
        "models"
      ],
      "title": "ProviderConfig",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "allowed_tools": {
      "items": {
        "type": "string"
      },
      "title": "Allowed Tools",
      "type": "array"
    },
    "budget": {
      "$ref": "#/$defs/InvestigationBudget"
    },
    "decision": {
      "$ref": "#/$defs/DecisionPolicy"
    },
    "investigation_id": {
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "title": "Investigation Id",
      "type": "string"
    },
    "provider": {
      "$ref": "#/$defs/ProviderConfig"
    },
    "schema_version": {
      "pattern": "^\\d+\\.\\d+$",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "investigation_id",
    "provider"
  ],
  "title": "InvestigationConfig",
  "type": "object"
}
