{
  "$defs": {
    "RecoveryArtifactFile": {
      "additionalProperties": false,
      "properties": {
        "byte_size": {
          "minimum": 0,
          "title": "Byte Size",
          "type": "integer"
        },
        "relative_path": {
          "pattern": "^[A-Za-z0-9._-]+$",
          "title": "Relative Path",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "relative_path",
        "byte_size",
        "sha256"
      ],
      "title": "RecoveryArtifactFile",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "pattern": "^[a-z0-9]+(?:[._/-][a-z0-9]+)*$",
      "title": "Artifact Id",
      "type": "string"
    },
    "artifact_type": {
      "const": "recovery_report",
      "default": "recovery_report",
      "title": "Artifact Type",
      "type": "string"
    },
    "bindings": {
      "additionalProperties": {
        "pattern": "^[a-f0-9]{64}$",
        "type": "string"
      },
      "title": "Bindings",
      "type": "object"
    },
    "files": {
      "items": {
        "$ref": "#/$defs/RecoveryArtifactFile"
      },
      "maxItems": 10,
      "minItems": 4,
      "title": "Files",
      "type": "array"
    },
    "generator_version": {
      "minLength": 1,
      "title": "Generator Version",
      "type": "string"
    },
    "incident_id": {
      "pattern": "^[a-z0-9]+(?:[._/-][a-z0-9]+)*$",
      "title": "Incident Id",
      "type": "string"
    },
    "payload_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Payload Sha256",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "enum": [
        "recovered",
        "recovering",
        "failed",
        "insufficient_data"
      ],
      "title": "Status",
      "type": "string"
    }
  },
  "required": [
    "artifact_id",
    "incident_id",
    "generator_version",
    "status",
    "payload_sha256",
    "bindings",
    "files"
  ],
  "title": "RecoveryArtifactManifest",
  "type": "object"
}
