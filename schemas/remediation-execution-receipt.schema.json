    "before_state_manifest_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Before State Manifest Sha256",
      "type": "string"
    },
    "executed_at": {
      "format": "date-time",
      "title": "Executed At",
      "type": "string"
    },
    "executed_by": {
      "pattern": "^[a-z0-9]+(?:[._/-][a-z0-9]+)*$",
      "title": "Executed By",
      "type": "string"
    },
    "execution_id": {
      "pattern": "^[a-z0-9]+(?:[._/-][a-z0-9]+)*$",
      "title": "Execution Id",
      "type": "string"
    },
    "incident_id": {
      "pattern": "^[a-z0-9]+(?:[._/-][a-z0-9]+)*$",
      "title": "Incident Id",
      "type": "string"
    },
    "plan_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Plan Sha256",
      "type": "string"
    },
    "receipt_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Receipt Sha256",
      "type": "string"
    },
    "remediation_id": {
      "pattern": "^[a-z0-9]+(?:[._/-][a-z0-9]+)*$",
      "title": "Remediation Id",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "const": "executed",
      "default": "executed",
      "title": "Status",
      "type": "string"
    },
    "token_nonce_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Token Nonce Sha256",
      "type": "string"
    },
    "token_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Token Sha256",
      "type": "string"
    }
  },
  "required": [
    "execution_id",
    "remediation_id",
    "incident_id",
    "executed_by",
    "executed_at",
    "plan_sha256",
    "approval_snapshot_sha256",
    "token_sha256",
    "token_nonce_sha256",
    "before_state_manifest_sha256",
    "after_state_payload_sha256",
    "action_receipts",
    "receipt_sha256"
