{
  "$defs": {
    "ActionExecutionReceipt": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "pattern": "^[a-z0-9]+(?:[._/-][a-z0-9]+)*$",
          "title": "Action Id",
          "type": "string"
        },
        "action_type": {
          "enum": [
            "deployment.rollback",
            "feature_flag.set",
            "configuration.restore"
          ],
          "title": "Action Type",
          "type": "string"
        },
        "after_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "After Sha256",
          "type": "string"
        },
        "before_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Before Sha256",
          "type": "string"
        },
        "inverse_action": {
          "discriminator": {
            "mapping": {
              "configuration.restore": "#/$defs/RestoreConfigurationAction",
              "deployment.rollback": "#/$defs/RollbackDeploymentAction",
              "feature_flag.set": "#/$defs/SetFeatureFlagAction"
            },
            "propertyName": "action_type"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/RollbackDeploymentAction"
            },
            {
              "$ref": "#/$defs/SetFeatureFlagAction"
            },
            {
              "$ref": "#/$defs/RestoreConfigurationAction"
            }
          ],
          "title": "Inverse Action"
        },
        "resource_id": {
          "pattern": "^[a-z0-9]+(?:[._/-][a-z0-9]+)*$",
          "title": "Resource Id",
          "type": "string"
        },
        "status": {
          "const": "executed",
          "default": "executed",
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "action_id",
        "action_type",
        "resource_id",
        "before_sha256",
        "after_sha256",
        "inverse_action"
      ],
      "title": "ActionExecutionReceipt",
      "type": "object"
    },
    "RestoreConfigurationAction": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "pattern": "^[a-z0-9]+(?:[._/-][a-z0-9]+)*$",
          "title": "Action Id",
          "type": "string"
        },
        "action_type": {
          "const": "configuration.restore",
          "default": "configuration.restore",
          "title": "Action Type",
          "type": "string"
        },
        "blast_radius": {
          "enum": [
            "single_instance",
            "single_service",
            "multi_service",
            "region",
            "global"
          ],
          "title": "Blast Radius",
          "type": "string"
        },
        "evidence_ids": {
          "items": {
            "pattern": "^[A-Za-z0-9]+(?:[._/-][A-Za-z0-9]+)*$",
            "type": "string"
          },
          "maxItems": 30,
          "minItems": 1,
          "title": "Evidence Ids",
          "type": "array"
        },
        "expected_current_version": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Expected Current Version",
          "type": "string"
        },
        "justification": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Justification",
          "type": "string"
        },
        "resource_id": {
          "pattern": "^[a-z0-9]+(?:[._/-][a-z0-9]+)*$",
          "title": "Resource Id",
          "type": "string"
        },
        "target_version": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Target Version",
          "type": "string"
        }
      },
      "required": [
        "action_id",
        "blast_radius",
        "evidence_ids",
        "justification",
        "resource_id",
        "expected_current_version",
        "target_version"
      ],
      "title": "RestoreConfigurationAction",
      "type": "object"
    },
    "RollbackDeploymentAction": {
      "additionalProperties": false,
