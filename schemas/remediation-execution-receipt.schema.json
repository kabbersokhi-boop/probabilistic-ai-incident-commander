          "title": "Justification",
          "type": "string"
        },
        "resource_id": {
          "pattern": "^[a-z0-9]+(?:[._/-][a-z0-9]+)*$",
          "title": "Resource Id",
          "type": "string"
        },
        "target_revision": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Target Revision",
          "type": "string"
        }
      },
      "required": [
        "action_id",
        "blast_radius",
        "evidence_ids",
        "justification",
        "resource_id",
        "expected_current_revision",
        "target_revision"
      ],
      "title": "RollbackDeploymentAction",
      "type": "object"
    },
    "SetFeatureFlagAction": {
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "pattern": "^[a-z0-9]+(?:[._/-][a-z0-9]+)*$",
          "title": "Action Id",
          "type": "string"
        },
        "action_type": {
          "const": "feature_flag.set",
          "default": "feature_flag.set",
          "title": "Action Type",
          "type": "string"
        },
        "blast_radius": {
          "enum": [
            "single_instance",
            "single_service",
            "multi_service",
            "region",
            "global"
          ],
          "title": "Blast Radius",
          "type": "string"
        },
        "desired_enabled": {
          "title": "Desired Enabled",
          "type": "boolean"
        },
        "evidence_ids": {
          "items": {
            "pattern": "^[A-Za-z0-9]+(?:[._/-][A-Za-z0-9]+)*$",
            "type": "string"
          },
          "maxItems": 30,
          "minItems": 1,
          "title": "Evidence Ids",
          "type": "array"
        },
        "expected_enabled": {
          "title": "Expected Enabled",
          "type": "boolean"
        },
        "justification": {
          "maxLength": 2000,
