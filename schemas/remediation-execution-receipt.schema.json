        "blast_radius",
        "evidence_ids",
        "justification",
        "resource_id",
        "expected_enabled",
        "desired_enabled"
      ],
      "title": "SetFeatureFlagAction",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "action_receipts": {
      "items": {
        "$ref": "#/$defs/ActionExecutionReceipt"
      },
      "maxItems": 10,
      "minItems": 1,
      "title": "Action Receipts",
      "type": "array"
    },
    "after_state_payload_sha256": {
      "pattern": "^[a-f0-9]{64}$",
