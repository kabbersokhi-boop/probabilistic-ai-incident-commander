{
  "additionalProperties": false,
  "properties": {
    "analytics_dir": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Analytics Dir"
    },
    "arguments": {
      "additionalProperties": true,
      "title": "Arguments",
      "type": "object"
    },
    "audit_dir": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Audit Dir"
    },
    "call_id": {
      "anyOf": [
        {
          "format": "uuid",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Call Id"
    },
    "dataset_dir": {
      "minLength": 1,
      "title": "Dataset Dir",
      "type": "string"
    },
    "detection_dir": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Detection Dir"
    },
    "evidence_dir": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Evidence Dir"
    },
    "impact_dir": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Impact Dir"
    },
    "incident_id": {
      "maxLength": 200,
      "minLength": 1,
      "title": "Incident Id",
      "type": "string"
    },
    "role": {
      "enum": [
        "observer",
        "investigator",
        "approver"
      ],
      "title": "Role",
      "type": "string"
    },
    "tool": {
      "maxLength": 80,
      "minLength": 1,
      "title": "Tool",
      "type": "string"
    },
    "tool_version": {
      "default": "1.0",
      "pattern": "^\\d+\\.\\d+$",
      "title": "Tool Version",
      "type": "string"
    }
  },
  "required": [
    "tool",
    "incident_id",
    "role",
    "dataset_dir"
  ],
  "title": "ToolRequest",
  "type": "object"
}
