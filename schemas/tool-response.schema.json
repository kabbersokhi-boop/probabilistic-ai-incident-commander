  "required": [
    "call_id",
    "incident_id",
    "tool",
    "tool_version",
    "policy_decision",
    "execution_status",
    "source_manifest_hashes",
    "row_count",
    "byte_count",
    "truncated",
    "evidence_record_ids",
    "normalized_arguments",
    "result_sha256"
