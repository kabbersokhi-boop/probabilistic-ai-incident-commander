    "evidence_record_ids": {
      "items": {
        "type": "string"
      },
      "title": "Evidence Record Ids",
      "type": "array"
    },
    "execution_status": {
      "enum": [
        "success",
        "error"
      ],
      "title": "Execution Status",
      "type": "string"
    },
    "incident_id": {
      "title": "Incident Id",
      "type": "string"
    },
    "normalized_arguments": {
      "additionalProperties": true,
      "title": "Normalized Arguments",
      "type": "object"
    },
    "policy_decision": {
      "enum": [
        "allow",
        "deny"
      ],
