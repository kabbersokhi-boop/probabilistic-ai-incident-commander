      "type": "string"
    },
    "result": {
      "default": null,
      "title": "Result"
    },
    "result_sha256": {
      "title": "Result Sha256",
      "type": "string"
    },
    "row_count": {
      "minimum": 0,
      "title": "Row Count",
      "type": "integer"
    },
    "source_manifest_hashes": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Source Manifest Hashes",
      "type": "object"
